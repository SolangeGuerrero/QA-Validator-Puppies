# Supabase project — anon key, safe to ship in the client bundle
VITE_INSFORGE_URL=https://PROJECT_REF.supabase.co
VITE_INSFORGE_ANON_KEY=eyJ...

# API URL — in production this is "/api" and nginx/Vercel proxies it
VITE_API_URL=http://localhost:3001

# Optional: comma-separated domain whitelist for Google OAuth. Empty = open demo.
# Example: VITE_ALLOWED_DOMAINS=acme.com,partner.com
VITE_ALLOWED_DOMAINS=

# Set to "true" to show the "Try the demo" button in /login
VITE_DEMO_MODE=true
