# Database — Supabase Postgres (use the Session Pooler URL for IPv4)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# Supabase Auth + Storage
INSFORGE_URL=https://PROJECT_REF.supabase.co
INSFORGE_SERVICE_KEY=eyJ...

# AI Provider (only google gemini direct is supported in this build)
AI_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy...

# Email — SendGrid (https://sendgrid.com)
SENDGRID_API_KEY=SG....
SENDGRID_FROM=Puppies QA <qa@puppies.dev>

# Public URL of the SPA — used for magic-link redirects
WEB_URL=http://localhost:5176

PORT=3001
NODE_ENV=development
