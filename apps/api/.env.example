# Database — Supabase Postgres (Session Pooler URL for IPv4 + DDL support)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# Supabase Auth + Storage
INSFORGE_URL=https://PROJECT_REF.supabase.co
INSFORGE_SERVICE_KEY=eyJ...

# AI Provider
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Email — SendGrid (optional, demo works without it)
SENDGRID_API_KEY=
SENDGRID_FROM=Puppies QA <noreply@yourdomain.com>

# Public URL of the SPA — used for magic-link redirects
WEB_URL=http://localhost:5176

PORT=3001
NODE_ENV=development
