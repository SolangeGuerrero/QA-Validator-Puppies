# Puppies QA — Docker stack env
# Copy to .env and fill in real credentials.

WEB_URL=http://localhost
WEB_PORT=80

# Database (Supabase Postgres — Session Pooler URL recommended for IPv4)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres

# Supabase
INSFORGE_URL=https://PROJECT_REF.supabase.co
INSFORGE_SERVICE_KEY=eyJ...

# AI Provider
AI_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM=Puppies QA <qa@puppies.dev>

PORT=3001
NODE_ENV=production
